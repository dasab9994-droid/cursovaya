<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" spacing="8" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.shop.controller.RegisterController"
      style="-fx-background-color: #FFFDE7; -fx-border-color: #FFF9C4; -fx-border-width: 2px; -fx-border-radius: 10; -fx-background-radius: 10;">
    <padding>
        <Insets top="20" right="40" bottom="20" left="40"/>
    </padding>

    <Label text="Регистрация заказчика" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #F57F17;">
        <font>
            <Font name="System Bold" size="18"/>
        </font>
    </Label>

    <TextField fx:id="nameField" promptText="Название организации / Имя" style="-fx-background-color: #FFF8E1; -fx-border-color: #FFE082; -fx-border-radius: 5; -fx-background-radius: 5; -fx-padding: 8;"/>
    <TextField fx:id="phoneField" promptText="Номер телефона" style="-fx-background-color: #FFF8E1; -fx-border-color: #FFE082; -fx-border-radius: 5; -fx-background-radius: 5; -fx-padding: 8;"/>
    <TextField fx:id="contactField" promptText="Контактное лицо" style="-fx-background-color: #FFF8E1; -fx-border-color: #FFE082; -fx-border-radius: 5; -fx-background-radius: 5; -fx-padding: 8;"/>
    <TextField fx:id="addressField" promptText="Адрес" style="-fx-background-color: #FFF8E1; -fx-border-color: #FFE082; -fx-border-radius: 5; -fx-background-radius: 5; -fx-padding: 8;"/>
    <TextField fx:id="loginField" promptText="Логин" style="-fx-background-color: #FFF8E1; -fx-border-color: #FFE082; -fx-border-radius: 5; -fx-background-radius: 5; -fx-padding: 8;"/>
    <PasswordField fx:id="passwordField" promptText="Пароль" style="-fx-background-color: #FFF8E1; -fx-border-color: #FFE082; -fx-border-radius: 5; -fx-background-radius: 5; -fx-padding: 8;"/>
    <PasswordField fx:id="confirmField" promptText="Повторите пароль" style="-fx-background-color: #FFF8E1; -fx-border-color: #FFE082; -fx-border-radius: 5; -fx-background-radius: 5; -fx-padding: 8;"/>

    <Label text="Пароль: минимум 8 символов, цифра, заглавная буква, спецсимвол"
           style="-fx-font-size: 11px; -fx-text-fill: #F9A825;" wrapText="true"/>

    <Label fx:id="errorLabel" style="-fx-text-fill: #C62828;" wrapText="true"/>

    <HBox spacing="10" alignment="CENTER">
        <Button text="Зарегистрироваться" onAction="#onRegister" defaultButton="true"
                style="-fx-background-color: #FFD54F; -fx-text-fill: #4E342E; -fx-font-weight: bold; -fx-border-radius: 5; -fx-background-radius: 5; -fx-padding: 8 20; -fx-cursor: hand;"/>
        <Button text="Назад ко входу" onAction="#onBackToLogin"
                style="-fx-background-color: #FFE082; -fx-text-fill: #4E342E; -fx-font-weight: bold; -fx-border-radius: 5; -fx-background-radius: 5; -fx-padding: 8 20; -fx-cursor: hand;"/>
    </HBox>
</VBox>