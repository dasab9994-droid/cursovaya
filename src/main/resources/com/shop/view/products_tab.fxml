<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.shop.controller.ProductsController"
            style="-fx-background-color: #FFFDE7;">

    <center>
        <TableView fx:id="table" style="-fx-background-color: #FFF8E1; -fx-border-color: #FFE082; -fx-border-radius: 5; -fx-background-radius: 5;">
            <columns>
                <TableColumn fx:id="colId" text="ID" prefWidth="40"
                             style="-fx-text-fill: #F57F17; -fx-font-weight: bold;"/>
                <TableColumn fx:id="colName" text="Название" prefWidth="180"
                             style="-fx-text-fill: #F57F17; -fx-font-weight: bold;"/>
                <TableColumn fx:id="colPrice" text="Цена" prefWidth="90"
                             style="-fx-text-fill: #F57F17; -fx-font-weight: bold;"/>
                <TableColumn fx:id="colInfo" text="Информация" prefWidth="280"
                             style="-fx-text-fill: #F57F17; -fx-font-weight: bold;"/>
                <TableColumn fx:id="colDelivery" text="Доставка?" prefWidth="80"
                             style="-fx-text-fill: #F57F17; -fx-font-weight: bold;"/>
            </columns>
        </TableView>
    </center>

    <bottom>
        <VBox spacing="8" style="-fx-padding: 15; -fx-background-color: #FFF8E1; -fx-border-color: #FFE082; -fx-border-width: 2 0 0 0; -fx-background-radius: 0 0 10 10;">
            <HBox spacing="8" style="-fx-padding: 5 0;">
                <TextField fx:id="nameField" promptText="Название" prefWidth="200"
                           style="-fx-background-color: #FFFDE7; -fx-border-color: #FFE082; -fx-border-radius: 5; -fx-background-radius: 5; -fx-padding: 8;"/>
                <TextField fx:id="priceField" promptText="Цена" prefWidth="100"
                           style="-fx-background-color: #FFFDE7; -fx-border-color: #FFE082; -fx-border-radius: 5; -fx-background-radius: 5; -fx-padding: 8;"/>
                <CheckBox fx:id="deliveryCheck" text="Доставка доступна"
                          style="-fx-text-fill: #4E342E; -fx-font-weight: bold; -fx-padding: 8 0 0 5;"/>
            </HBox>

            <TextArea fx:id="infoField" promptText="Информация о товаре" prefRowCount="2" wrapText="true"
                      style="-fx-background-color: #FFFDE7; -fx-border-color: #FFE082; -fx-border-radius: 5; -fx-background-radius: 5; -fx-padding: 8;"/>

            <HBox spacing="8" style="-fx-padding: 5 0;">
                <Button fx:id="addButton" text="Добавить" onAction="#onAdd"
                        style="-fx-background-color: #FFD54F; -fx-text-fill: #4E342E; -fx-font-weight: bold; -fx-border-radius: 5; -fx-background-radius: 5; -fx-padding: 8 20; -fx-cursor: hand;"/>
                <Button fx:id="updateButton" text="Изменить" onAction="#onUpdate"
                        style="-fx-background-color: #FFE082; -fx-text-fill: #4E342E; -fx-font-weight: bold; -fx-border-radius: 5; -fx-background-radius: 5; -fx-padding: 8 20; -fx-cursor: hand;"/>
                <Button fx:id="deleteButton" text="Удалить" onAction="#onDelete"
                        style="-fx-background-color: #FFCC80; -fx-text-fill: #4E342E; -fx-font-weight: bold; -fx-border-radius: 5; -fx-background-radius: 5; -fx-padding: 8 20; -fx-cursor: hand;"/>
                <Button text="Обновить список" onAction="#onRefresh"
                        style="-fx-background-color: #FFF176; -fx-text-fill: #4E342E; -fx-font-weight: bold; -fx-border-radius: 5; -fx-background-radius: 5; -fx-padding: 8 20; -fx-cursor: hand;"/>
            </HBox>

            <Label fx:id="errorLabel" style="-fx-text-fill: #C62828; -fx-font-weight: bold;" wrapText="true"/>
        </VBox>
    </bottom>
</BorderPane>